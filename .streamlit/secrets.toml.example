# Copia este archivo a secrets.toml en la misma carpeta (.streamlit/).
# secrets.toml NO debe subirse a git (está en .gitignore).

# --- Login de la aplicación (quién puede abrir la app) ---
[auth]
username = "admin"
password = "cambia_esta_contraseña"

# --- PostgreSQL / Supabase ---
#
# El host directo db.*.supabase.co suele ser solo IPv6. Para IPv4 usa el pooler del panel.
#
# Transaction pooler (ejemplo real de proyecto — completa solo la contraseña del panel):
#   - Puerto 6543
#   - Usuario: postgres.PROJECTREF (el ref es el id del proyecto en Supabase)

[database]
host = "aws-1-us-east-2.pooler.supabase.com"
port = 6543
name = "postgres"
user = "postgres.ivotmktmqvkblmrocbhm"
password = "TU_PASSWORD_DE_SUPABASE"
sslmode = "require"

# Session pooler (otro modo del panel): suele puerto 5432 y user "postgres"
#
# [database]
# host = "aws-0-REGION.pooler.supabase.com"
# port = 5432
# name = "postgres"
# user = "postgres"
# password = "TU_PASSWORD"
# sslmode = "require"

# Opcional: forzar IPv4 con IP literal
# hostaddr = "1.2.3.4"
# prefer_ipv4 = true

# Alternativa: URL (Transaction pooler)
# [database]
# url = "postgresql://postgres.ivotmktmqvkblmrocbhm:TU_PASSWORD@aws-1-us-east-2.pooler.supabase.com:6543/postgres?sslmode=require"
