# Copia a .env y completa la contraseña (no subas .env a git).
# Conexión directa Postgres / Supabase

SUPABASE_DB_HOST=db.ivotmktmqvkblmrocbhm.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# Obligatorio para Supabase en la mayoría de casos (por defecto en código: require)
# SUPABASE_DB_SSLMODE=require

# Alternativa: una sola URL
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.ivotmktmqvkblmrocbhm.supabase.co:5432/postgres?sslmode=require
